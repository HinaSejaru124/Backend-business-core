# Copier en .env.local (gitignoré) et renseigner les vraies valeurs.
# Ne jamais committer de vraie clé API ici.

BCAAS_BASE_URL=http://localhost:8081
BCAAS_CLIENT_ID=bck_xxxxxxxxx
BCAAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Renseigné après la création manuelle du type PHARMA_TEST (cf. SPIKE-RESULTATS.md) —
# le bootstrap automatique prendra le relai une fois le blocage Kernel levé.
BCAAS_TYPE_ID=
BCAAS_VERSION_NUMBER=1

PHARMACORE_DB_USER=pharmacore_app
PHARMACORE_DB_PASSWORD=pharmacore_app
