# Copier en .env et adapter. Ne jamais committer de secrets réels.

# --- PostgreSQL (docker-compose) ---
BC_DB_NAME=businesscore
BC_DB_SUPERUSER=postgres
BC_DB_SUPERPASSWORD=postgres
BC_DB_PORT=5432

# --- Connexions applicatives (rôles créés par infra/postgres/01-roles.sql) ---
# Runtime réactif (non-owner, soumis à RLS)
BC_R2DBC_URL=r2dbc:postgresql://localhost:5432/businesscore
BC_DB_APP_USER=bc_app
BC_DB_APP_PASSWORD=bc_app
# Migrations Liquibase (owner, JDBC)
BC_JDBC_URL=jdbc:postgresql://localhost:5432/businesscore
BC_DB_OWNER_USER=bc_owner
BC_DB_OWNER_PASSWORD=bc_owner

# --- Redis ---
BC_REDIS_HOST=localhost
BC_REDIS_PORT=6379

# --- Kafka ---
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
BC_KAFKA_PORT=9092
# En prod yowyob (SASL/SCRAM) :
# SPRING_KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
# SPRING_KAFKA_PROPERTIES_SASL_MECHANISM=SCRAM-SHA-256
# SPRING_KAFKA_PROPERTIES_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="business-core" password="CHANGE_ME";

# --- Kernel RT-Comops ---
# En dev/test : WireMock. En prod (réseau yowyob) : http://kernel-core-kernel-layer-1:8080
KERNEL_BASE_URL=http://localhost:8089
# ClientApplication PLATEFORME du Business Core (fournie par le DevOps en prod ; ne pas committer)
KERNEL_CLIENT_ID=
KERNEL_CLIENT_SECRET=

# --- Sécurité ---
# Clé AES-256-GCM (32 octets) pour chiffrer les secrets kernel au repos. OBLIGATOIRE en prod.
BC_ENCRYPTION_KEY=dev-only-insecure-key-change-me-32b
BC_CORS_ORIGINS=*

# --- Profil ---
SPRING_PROFILES_ACTIVE=dev
