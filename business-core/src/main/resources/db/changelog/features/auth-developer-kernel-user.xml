<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Identifiant utilisateur kernel (claim JWT sub) pour lier le compte développeur au login. -->
    <changeSet id="auth-dev-001-kernel-user-id" author="dev">
        <addColumn tableName="developer_account">
            <column name="kernel_user_id" type="varchar(128)"/>
        </addColumn>
        <addUniqueConstraint tableName="developer_account" columnNames="kernel_user_id"
                             constraintName="uq_developer_account_kernel_user_id"/>
    </changeSet>

</databaseChangeLog>
