# Copier en .env et renseigner avant le premier démarrage : `cp .env.example .env`.
# Ne jamais committer le fichier .env rempli (secrets réels).

# --- Base de données (créée au premier démarrage du conteneur) ---
BC_DB_NAME=businesscore
BC_DB_OWNER_PASSWORD=change_me_owner_password
BC_DB_APP_PASSWORD=change_me_app_password

# --- Kernel RT-Comops (service externe) ---
# ATTENTION : ne JAMAIS laisser cette valeur vide. Une variable d'environnement vide-mais-présente
# n'est PAS équivalente à une variable absente pour Spring : ${KERNEL_BASE_URL:defaut} n'utilise le
# défaut que si la variable est totalement absente. Une valeur vide ici retombe sur le garde-fou codé
# en dur dans KernelProperties.java (http://localhost:8089, l'adresse de WireMock) — pas sur le kernel
# de production — et toute connexion échoue silencieusement (« Connection refused », masqué en 503).
# Renseigne l'URL réelle explicitement :
KERNEL_BASE_URL=https://kernel-core.yowyob.com
KERNEL_CLIENT_ID=
KERNEL_CLIENT_SECRET=

# --- Sécurité (obligatoire : clé AES-256-GCM de 32 octets minimum) ---
BC_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_MINIMUM_STP

# --- CORS (domaine(s) autorisés, séparés par des virgules ; * = tout autoriser) ---
BC_CORS_ORIGINS=*

# --- Administrateurs de la console admin Business Core (emails séparés par des virgules) ---
BC_ADMIN_EMAILS=

# --- Profil Spring actif ---
SPRING_PROFILES_ACTIVE=prod

# --- Port HTTP exposé sur l'hôte ---
APP_PORT=8080
