<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Socle (lead). Tables partagées + convention multi-tenant + RLS.
      Préfixe d'IDs : socle-xxx. NE JAMAIS modifier ce fichier dans une feature ; ajouter le sien.
    -->

    <!-- developer_account : registre des développeurs. DÉFINIT le tenant, donc PAS de tenant_id ni de RLS. -->
    <changeSet id="socle-001-developer-account" author="socle">
        <createTable tableName="developer_account">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="bc_client_id" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="bc_api_key_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="kernel_client_id" type="varchar(128)"/>
            <column name="kernel_secret_encrypted" type="text"/>
            <column name="plan" type="varchar(32)" defaultValue="FREE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(16)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- type_metier : coquille socle (Dev 2 enrichit le domaine/API). Tenant-owned -> tenant_id + RLS. -->
    <changeSet id="socle-002-type-metier" author="socle">
        <createTable tableName="type_metier">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="business_domain_id" type="uuid"/>
            <column name="code" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="nom" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="varchar(16)" defaultValue="BROUILLON">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="type_metier" columnNames="tenant_id,code"
                             constraintName="uq_type_metier_tenant_code"/>
    </changeSet>

    <!-- version_type : versions immuables d'un type. Tenant-owned -> tenant_id + RLS. -->
    <changeSet id="socle-003-version-type" author="socle">
        <createTable tableName="version_type">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="type_metier_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="numero" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="immuable" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="publiee_le" type="timestamptz"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="version_type" baseColumnNames="type_metier_id"
                                 referencedTableName="type_metier" referencedColumnNames="id"
                                 constraintName="fk_version_type_type_metier"/>
        <addUniqueConstraint tableName="version_type" columnNames="type_metier_id,numero"
                             constraintName="uq_version_type_type_numero"/>
    </changeSet>

    <!--
      Barrière 3 — RLS sur les tables tenant-owned du socle.
      ENABLE + FORCE (le propriétaire lui-même est soumis), policy USING (lecture/maj/suppression)
      + WITH CHECK (empêche un INSERT cross-tenant).
      NULLIF(current_setting('app.current_tenant', true), '') : le 2e argument 'true' évite l'erreur
      si la variable n'est jamais posée (renvoie NULL) ; NULLIF(...,'') ramène aussi la chaîne vide à
      NULL (set_config sur un GUC custom laisse '' plutôt que NULL). Résultat : fail closed dans tous
      les cas (aucune ligne visible, aucun INSERT possible) tant que le contexte tenant n'est pas posé.
      Snippet de référence : les features doivent reproduire ce bloc pour CHACUNE de leurs tables tenant.
    -->
    <changeSet id="socle-004-rls-type-metier" author="socle">
        <sql splitStatements="true" endDelimiter=";">
            ALTER TABLE type_metier ENABLE ROW LEVEL SECURITY;
            ALTER TABLE type_metier FORCE ROW LEVEL SECURITY;
            CREATE POLICY tenant_isolation ON type_metier
                USING (tenant_id = NULLIF(current_setting('app.current_tenant', true), '')::uuid)
                WITH CHECK (tenant_id = NULLIF(current_setting('app.current_tenant', true), '')::uuid);
        </sql>
        <rollback>
            <sql>
                DROP POLICY IF EXISTS tenant_isolation ON type_metier;
                ALTER TABLE type_metier NO FORCE ROW LEVEL SECURITY;
                ALTER TABLE type_metier DISABLE ROW LEVEL SECURITY;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="socle-005-rls-version-type" author="socle">
        <sql splitStatements="true" endDelimiter=";">
            ALTER TABLE version_type ENABLE ROW LEVEL SECURITY;
            ALTER TABLE version_type FORCE ROW LEVEL SECURITY;
            CREATE POLICY tenant_isolation ON version_type
                USING (tenant_id = NULLIF(current_setting('app.current_tenant', true), '')::uuid)
                WITH CHECK (tenant_id = NULLIF(current_setting('app.current_tenant', true), '')::uuid);
        </sql>
        <rollback>
            <sql>
                DROP POLICY IF EXISTS tenant_isolation ON version_type;
                ALTER TABLE version_type NO FORCE ROW LEVEL SECURITY;
                ALTER TABLE version_type DISABLE ROW LEVEL SECURITY;
            </sql>
        </rollback>
    </changeSet>

    <!--
      Alignement tenant (Partie A) : le tenant BC doit être le tenant kernel.
      - kernel_tenant_id : le tid renvoyé par le kernel (sign-up puis login). Sert de tenant_id
        pour toutes les données métier, quel que soit le mode d'auth (clé API ou JWT).
      - email : permet de retrouver le compte au login (le login est public, sans clé BC) pour
        confirmer/renseigner le kernel_tenant_id s'il est absent.
    -->
    <changeSet id="socle-006-developer-account-tenant-email" author="socle">
        <addColumn tableName="developer_account">
            <column name="kernel_tenant_id" type="uuid"/>
            <column name="email" type="varchar(255)"/>
        </addColumn>
        <addUniqueConstraint tableName="developer_account" columnNames="email"
                             constraintName="uq_developer_account_email"/>
    </changeSet>

    <!--
      Portail multi-clés (Partie B) : plusieurs clés API par développeur.
      Table sans RLS (comme developer_account) : sert à établir le tenant, ne porte aucune donnée métier.
    -->
    <changeSet id="socle-007-api-key" author="socle">
        <createTable tableName="api_key">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="developer_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="prefix" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="key_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(64)" defaultValue="Default">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(16)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_used_at" type="timestamptz"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="api_key" baseColumnNames="developer_id"
                                 referencedTableName="developer_account" referencedColumnNames="id"
                                 constraintName="fk_api_key_developer"/>
        <createIndex tableName="api_key" indexName="idx_api_key_developer_status">
            <column name="developer_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <!-- Migre les clés existantes (colonnes de developer_account) vers la table api_key. -->
    <changeSet id="socle-008-migrate-legacy-keys" author="socle">
        <sql>
            INSERT INTO api_key (id, developer_id, prefix, key_hash, name, status, created_at)
            SELECT gen_random_uuid(), id, bc_client_id, bc_api_key_hash, 'Default', 'ACTIVE', created_at
            FROM developer_account
            WHERE bc_client_id IS NOT NULL;
        </sql>
        <rollback>
            <sql>DELETE FROM api_key;</sql>
        </rollback>
    </changeSet>

    <!-- Les colonnes de clé migrent dans api_key : on les retire de developer_account. -->
    <changeSet id="socle-009-drop-legacy-key-columns" author="socle">
        <dropUniqueConstraint tableName="developer_account" constraintName="developer_account_bc_client_id_key"/>
        <dropColumn tableName="developer_account" columnName="bc_client_id"/>
        <dropColumn tableName="developer_account" columnName="bc_api_key_hash"/>
    </changeSet>

    <!-- Dashboard (B5) : agrégat quotidien d'usage par clé API. -->
    <changeSet id="socle-010-api-key-usage-daily" author="socle">
        <createTable tableName="api_key_usage_daily">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="api_key_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="jour" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="total" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="errors" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="p95_ms" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="api_key_usage_daily" columnNames="api_key_id,jour"
                             constraintName="uq_api_key_usage_daily_key_jour"/>
    </changeSet>

</databaseChangeLog>
