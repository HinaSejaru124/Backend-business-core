<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005" author="bcaas-team">
        <comment>Tables workflow — Moteur Saga</comment>
        <createTable tableName="bcaas_workflows">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="workflow_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="correlation_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="initiated_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="current_step_index" type="INTEGER" defaultValueNumeric="0"/>
            <column name="started_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="bcaas_workflow_steps">
            <column name="id" type="UUID" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workflow_id" type="UUID">
                <constraints nullable="false"
                    foreignKeyName="fk_steps_workflow"
                    references="bcaas_workflows(id)"/>
            </column>
            <column name="step_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="step_order" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="TEXT"/>
            <column name="started_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex tableName="bcaas_workflows" indexName="idx_workflows_tenant_status">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="bcaas_workflows" indexName="idx_workflows_correlation">
            <column name="correlation_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
