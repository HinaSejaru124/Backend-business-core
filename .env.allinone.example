# Copier en .env.allinone et adapter avant le premier démarrage.
# Ne jamais committer le fichier .env.allinone rempli (secrets réels).

# --- Kernel RT-Comops (service externe, DEJA en place — laisser vide pour utiliser
#     le kernel-core de production yowyob par défaut) ---
KERNEL_BASE_URL=
KERNEL_CLIENT_ID=
KERNEL_CLIENT_SECRET=

# --- Sécurité (obligatoire en prod : clé AES-256-GCM de 32 octets) ---
BC_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_MINIMUM_STP

# --- CORS (domaine(s) du frontend, séparés par des virgules ; * = tout autoriser) ---
BC_CORS_ORIGINS=*

# --- Administrateurs de la console admin Business Core ---
BC_ADMIN_EMAILS=techlan500@gmail.com

# --- Profil Spring actif ---
SPRING_PROFILES_ACTIVE=prod
